# Environment Variables for HRAOI Website
# Copy this file to .env.local and fill in your values

# ==========================================
# DATABASE OPTIONS - Choose one:
# ==========================================

# Option 1: Hostinger PostgreSQL Database
# Format: postgresql://username:password@hostname:port/database_name
# Get from: Hostinger hPanel → Databases → PostgreSQL
# DATABASE_URL="postgresql://hroi_user:your-password@pg123.hostinger.com:5432/hroi_db"

# Option 2: Hostinger MySQL Database (requires Prisma schema change)
# Format: mysql://username:password@hostname:port/database_name
# Get from: Hostinger hPanel → Databases → MySQL
# DATABASE_URL="mysql://hroi_user:your-password@mysql123.hostinger.com:3306/hroi_db"

# Option 3: Supabase PostgreSQL (Current/Recommended)
# Get this from: https://supabase.com → Project Settings → Database → Connection string → URI
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Option 4: Local PostgreSQL (for development)
# DATABASE_URL="postgresql://postgres:password@localhost:5432/hroi_local"

# NextAuth
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Supabase Storage
# URL: Settings -> API -> Project URL
SUPABASE_URL="https://your-project.supabase.co"
# Key: Settings -> API -> service_role (Secret Key)
# IMPORTANT: This key has admin access. Use only on the server.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Bucket name you created in Storage (e.g., hraoi-assets)
SUPABASE_STORAGE_BUCKET="hraoi-assets"
